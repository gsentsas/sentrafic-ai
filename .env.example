# PostgreSQL Configuration
POSTGRES_USER=sentrafic
POSTGRES_PASSWORD=sentrafic_dev
POSTGRES_DB=sentrafic
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Database Connection String (used by services)
DATABASE_URL=postgresql://sentrafic:sentrafic_dev@postgres:5432/sentrafic

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

# JWT Authentication
JWT_SECRET=change-me-in-production-use-strong-random-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Backend API Configuration
BACKEND_URL=http://backend-api:8000
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=4

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=SEN TRAFIC AI
NEXT_PUBLIC_APP_VERSION=1.0.0-MVP

# Vision Engine Configuration
YOLO_MODEL=yolov8n.pt
YOLO_CONFIDENCE=0.5
YOLO_IOU=0.45
VISION_CAMERA_ID=1
VISION_CAMERA_NAME=Demo Camera
VISION_SOURCE=samples/videos/demo.mp4
VISION_FPS=30
VISION_FRAME_WIDTH=1280
VISION_FRAME_HEIGHT=720
VISION_BATCH_SIZE=1
VISION_USE_GPU=false
VISION_GPU_DEVICE=0

# Vision Engine Backend Integration
VISION_BACKEND_URL=http://backend-api:8000
VISION_API_KEY=your-api-key-here
VISION_PUBLISH_INTERVAL=5

# Application Settings
APP_DEBUG=false
APP_ENVIRONMENT=development
LOG_LEVEL=INFO

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8000

# Email Configuration (optional, for alerts)
MAIL_SERVER=localhost
MAIL_PORT=587
MAIL_USERNAME=noreply@sentrafic.sn
MAIL_PASSWORD=your-email-password
MAIL_FROM=SEN TRAFIC AI <noreply@sentrafic.sn>
MAIL_USE_TLS=true

# Storage Configuration
STORAGE_BACKEND=local
STORAGE_PATH=/tmp/sentrafic-storage
MAX_UPLOAD_SIZE=104857600

# Analytics Configuration
ENABLE_ANALYTICS=true
ANALYTICS_BATCH_SIZE=100
ANALYTICS_BATCH_TIMEOUT=60

# Monitoring and Health Checks
HEALTH_CHECK_INTERVAL=30
CAMERA_HEALTH_CHECK_INTERVAL=60
DATABASE_POOL_SIZE=20
DATABASE_POOL_RECYCLE=3600

# Security Settings
SECURE_COOKIES=false
SAME_SITE_COOKIES=lax
ALLOW_ORIGIN_REGEX=^http://localhost:.*

# Cache Configuration
CACHE_TTL_DASHBOARD=300
CACHE_TTL_ANALYTICS=600
CACHE_TTL_ALERTS=60

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# Deployment Environment
DEPLOYMENT_ENV=development
DEPLOYMENT_REGION=senegal

# Docker Compose Service Names
DOCKER_POSTGRES_SERVICE=postgres
DOCKER_REDIS_SERVICE=redis
DOCKER_BACKEND_SERVICE=backend-api
DOCKER_DASHBOARD_SERVICE=dashboard
DOCKER_VISION_SERVICE=vision-engine
